{
  "manifest_version": 3,
  "name": "multisport420",
  "version": "0.2.0",
  "description": "TODO: describe",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "multisport420",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://pooembed.eu/embed-noads/*"
      ],
      "js": [
        "pooembed.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://embedsports.top/embed/*"
      ],
      "js": [
        "embedsports.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
